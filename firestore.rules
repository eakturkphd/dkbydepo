rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /assignments/{courseId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /courseParts/{courseId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn() && (isAdmin() || resource.data.teacherId == request.auth.uid || resource.data.createdBy == request.auth.uid);
    }

    match /occupancy/{occupancyId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }
  }
}
